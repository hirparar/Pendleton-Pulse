generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  INTERPRETER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DENIED
}

model UserProfile {
  id          String         @id @default(cuid())
  clerkUserId String         @unique
  email       String?
  role        Role           @default(INTERPRETER)
  status      ApprovalStatus @default(PENDING)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNote  String?

  @@index([role, status])
  @@index([createdAt])
}
