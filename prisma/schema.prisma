generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider    = "postgresql"
  url         = env("DATABASE_URL")
}

enum Role {
  ADMIN
  INTERPRETER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DENIED
}

model UserProfile {
  id          String         @id @default(cuid())
  clerkUserId String         @unique
  email       String?
  role        Role           @default(INTERPRETER)
  status      ApprovalStatus @default(PENDING)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNote  String?

  interpreterProfile InterpreterProfile?
  auditEvents        InterpreterAuditEvent[]

  @@index([role, status])
  @@index([createdAt])
}


model InterpreterProfile {
  id             String   @id @default(cuid())
  userProfileId  String   @unique

  displayName    String?
  phone          String?
  location       String?  // city/region for now
  bio            String?
  languages      String[] // Postgres text[]
  certifications String[] // text[]
  experienceYears Int?
  preferredModes String[] // e.g. ["in_person","remote"]
  availabilityNote String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userProfile    UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model InterpreterAuditEvent {
  id            String   @id @default(cuid())
  userProfileId String

  action        String   // "APPROVED" | "DENIED" | "PROFILE_UPDATED" | etc
  actor         String?  // admin email / clerk id
  note          String?
  meta          Json?
  createdAt     DateTime @default(now())

  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@index([userProfileId, createdAt])
}
