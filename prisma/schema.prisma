generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  INTERPRETER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DENIED
}

enum AssignmentStatus {
  OPEN
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum VisibilityMode {
  ALL
  RESTRICTED
}

enum InterpreterLinkStatus {
  ASSIGNED
  REMOVED
}

enum DeliveryMode {
  IN_PERSON
  REMOTE
  VIDEO_RELAY
  VIDEO_REMOTE
}

model UserProfile {
  id          String         @id @default(cuid())
  clerkUserId String         @unique
  email       String?        @unique
  role        Role           @default(INTERPRETER)
  status      ApprovalStatus @default(PENDING)
  isActive    Boolean        @default(true)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  interpreterProfile InterpreterProfile?
  auditEvents        AuditEvent[]
  assignmentsCreated Assignment[]            @relation("CreatedBy")
  assignmentLinks    AssignmentInterpreter[]
  visibilityGrants   AssignmentVisibility[]
  availabilitySlots  AvailabilitySlot[]

  @@index([role, status])
  @@index([role, isActive])
}

model InterpreterProfile {
  id              String      @id @default(cuid())
  userProfileId   String      @unique
  displayName     String?
  phone           String?
  location        String?
  bio             String?
  languages       String[]
  certifications  String[]
  experienceYears Int?
  preferredModes  String[]
  timezone        String      @default("America/New_York")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  userProfile     UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
}

model AvailabilitySlot {
  id            String                @id @default(cuid())
  userProfileId String
  date          DateTime
  startMin      Int
  endMin        Int
  timezone      String                @default("America/New_York")
  templateId    String?
  note          String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  userProfile   UserProfile           @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  template      AvailabilityTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@unique([userProfileId, date, startMin, endMin])
  @@index([userProfileId, date])
  @@index([date])
}

model AvailabilityTemplate {
  id            String             @id @default(cuid())
  userProfileId String
  name          String
  timezone      String             @default("America/New_York")
  days          Json
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  slots         AvailabilitySlot[]

  @@index([userProfileId])
}

model Assignment {
  id                     String @id @default(cuid())
  createdByUserProfileId String

  // Core identity
  title              String
  clientName         String
  clientOrganization String?
  languagePair       String
  assignmentType     String
  deliveryMode       DeliveryMode @default(IN_PERSON)

  // Scheduling
  scheduledStart DateTime
  scheduledEnd   DateTime
  timezone       String   @default("America/New_York")

  // In-person logistics
  location           String
  address            String?
  roomFloor          String?
  parkingNotes       String?
  accessInstructions String?
  dresscode          String?

  // Remote logistics
  meetingLink     String?
  meetingPassword String?
  platformNotes   String?

  // Staffing & status
  interpretersNeeded Int              @default(1)
  status             AssignmentStatus @default(OPEN)
  visibilityMode     VisibilityMode   @default(ALL)
  isUrgent           Boolean          @default(false)

  // Interpreter requirements
  requiredLanguagePair    String?
  requiredCertifications  String[]
  requiredExperienceYears Int?
  requiredModes           String[]

  // Compensation
  compensationRate      Float?
  compensationUnit      String?
  compensationNotes     String?
  isCompensationVisible Boolean @default(true)

  // Notes
  specialNotes  String?
  internalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy    UserProfile             @relation("CreatedBy", fields: [createdByUserProfileId], references: [id], onDelete: Restrict)
  interpreters AssignmentInterpreter[]
  visibility   AssignmentVisibility[]
  auditEvents  AuditEvent[]            @relation("AssignmentAudit")

  @@index([status, scheduledStart])
  @@index([createdByUserProfileId])
  @@index([deliveryMode, status])
  @@index([isUrgent])
}

model AssignmentInterpreter {
  id            String                @id @default(cuid())
  assignmentId  String
  userProfileId String
  status        InterpreterLinkStatus @default(ASSIGNED)
  assignedAt    DateTime              @default(now())
  removedAt     DateTime?
  note          String?
  assignment    Assignment            @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userProfile   UserProfile           @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userProfileId])
  @@index([userProfileId])
  @@index([assignmentId])
}

model AssignmentVisibility {
  id            String      @id @default(cuid())
  assignmentId  String
  userProfileId String
  createdAt     DateTime    @default(now())
  assignment    Assignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userProfileId])
  @@index([assignmentId])
  @@index([userProfileId])
}

model AuditEvent {
  id            String       @id @default(cuid())
  userProfileId String?
  assignmentId  String?
  action        String
  actor         String?
  note          String?
  meta          Json?
  createdAt     DateTime     @default(now())
  userProfile   UserProfile? @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  assignment    Assignment?  @relation("AssignmentAudit", fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([userProfileId, createdAt])
  @@index([assignmentId, createdAt])
}
